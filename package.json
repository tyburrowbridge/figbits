{
  "name": "figbits",
  "version": "0.1.0",
  "description": "Figma comment digest to Slack",
  "type": "module",
  "bin": {
    "figbits": "./dist/bin/figbits.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node ./dist/bin/figbits.js",
    "test": "node --test --import tsx 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
